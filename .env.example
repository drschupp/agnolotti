# Anthropic API key for Claude Sonnet
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# Agno telemetry (set to false to disable)
AGNO_TELEMETRY=false

# Database Configuration (defaults match compose.yaml)
# DB_USER=ai
# DB_PASS=ai
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=ai

# Docker Image Configuration
# IMAGE_NAME=agnolotti
# IMAGE_TAG=latest
